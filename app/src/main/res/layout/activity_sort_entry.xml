<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fitsSystemWindows="true"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:titleCentered="true"
            app:titleTextAppearance="@style/TextAppearance.Aegis.Toolbar.Title"
            app:navigationIcon="@drawable/ic_outline_arrow_left_alt_24" />

    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:overScrollMode="never">

    <com.garado.aegis.ui.components.light.LightOptionGroup
        android:id="@+id/sort_option_group"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="26dp" >

        <com.garado.aegis.ui.components.light.LightSelectorButton
            android:id="@+id/sort_custom"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:lightValue="@string/sort_custom" />

        <com.garado.aegis.ui.components.light.LightSelectorButton
            android:id="@+id/sort_issuer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:lightValue="@string/sort_alphabetically" />

        <com.garado.aegis.ui.components.light.LightSelectorButton
            android:id="@+id/sort_issuer_reversed"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:lightValue="@string/sort_alphabetically_reverse" />

        <com.garado.aegis.ui.components.light.LightSelectorButton
            android:id="@+id/sort_account"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:lightValue="@string/sort_alphabetically_name" />

        <com.garado.aegis.ui.components.light.LightSelectorButton
            android:id="@+id/sort_account_reversed"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:lightValue="@string/sort_alphabetically_name_reverse" />

        <com.garado.aegis.ui.components.light.LightSelectorButton
            android:id="@+id/sort_usage_count"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:lightValue="@string/sort_usage_count" />

        <com.garado.aegis.ui.components.light.LightSelectorButton
            android:id="@+id/sort_last_used"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:lightValue="@string/sort_last_used" />

    </com.garado.aegis.ui.components.light.LightOptionGroup>

    </ScrollView>

</LinearLayout>
